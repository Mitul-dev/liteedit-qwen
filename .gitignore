# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
.env
.venv
env/
venv/

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Model weights (too large for git) ─────────────────────────────
*.bin
*.safetensors
*.pt
*.pth
*.ckpt

# ── Results: large files (don't commit) ───────────────────────────
results/images/          # edited output images (can be re-generated)
results/metrics/*.json   # per-image JSON files (can be re-generated)
results/lora_checkpoints/*/adapter_model.bin
results/lora_checkpoints/*/adapter_model.safetensors
results/lora_checkpoints/*/optimizer.pt

# ── Results: keep these (commit to share paper outputs) ───────────
!results/metrics/*.csv        # summary CSVs — small, useful to track
!results/tables/*.tex         # LaTeX tables — paste into paper
!results/figures/*.png        # paper figures — share with collaborators
!results/lora_checkpoints/*/train_meta.json  # training metadata

# ── Data ──────────────────────────────────────────────────────────
data/train/
data/test/

# ── IDE / OS ──────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
